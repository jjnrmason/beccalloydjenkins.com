@inject NavigationManager NavigationManager

<header>
    <nav class="site-nav">
        <a href="@baseUrl" class="logo">Becca Lloyd-Jenkins</a>

        <div class="nav-links hidden md:flex gap-1">
            <a href="@baseUrl" class="@(IsActive("") ? "active" : "")">Work</a>
            <a href="@($"{baseUrl}about")" class="@(IsActive("about") ? "active" : "")">About</a>
            <a href="mailto:beccamaedesigns@outlook.com" style="color: var(--color-accent)">Contact</a>
        </div>

        <button @onclick="ToggleMenu" class="md:hidden" style="background:none;border:none;cursor:pointer;padding:0.25rem;" aria-label="Toggle menu">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:1.5rem;height:1.5rem;color:var(--color-text)">
                @if (isMenuOpen)
                {
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                }
                else
                {
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                }
            </svg>
        </button>
    </nav>

    @if (isMenuOpen)
    {
        <div class="mobile-menu md:hidden">
            <a href="@baseUrl" @onclick="CloseMenu">Work</a>
            <a href="@($"{baseUrl}about")" @onclick="CloseMenu">About</a>
            <a href="mailto:beccamaedesigns@outlook.com" style="color: var(--color-accent)">Contact</a>
        </div>
    }
</header>

@code {
    private string baseUrl = "/";
    private bool isMenuOpen = false;

    protected override void OnInitialized()
    {
        baseUrl = NavigationManager.BaseUri;
    }

    private void ToggleMenu() => isMenuOpen = !isMenuOpen;
    private void CloseMenu() => isMenuOpen = false;

    private bool IsActive(string segment)
    {
        var current = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).TrimEnd('/');
        return current == segment;
    }
}
