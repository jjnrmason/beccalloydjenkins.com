@page "/folder/{FolderName}"
@inject NavigationManager NavigationManager

<div class="page-content">
    <div style="margin-bottom:1.5rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
        <div>
            <a href="@baseUrl" class="back-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                All Work
            </a>
            <h1 style="font-family:var(--font-heading);font-size:2rem;font-weight:500;margin-top:0.25rem;">@FolderTitle</h1>
        </div>
        <span style="font-size:0.875rem;color:var(--color-text-muted);">@Images.Count image@(Images.Count == 1 ? "" : "s")</span>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;">
        @foreach (var image in Images)
        {
            <div class="gallery-card" @onclick="() => OpenLightbox(image)" role="button" tabindex="0" @onkeydown="@((e) => { if (e.Key == "Enter") OpenLightbox(image); })">
                <div class="aspect-square-wrapper">
                    <img src="@($"{baseUrl}images/{FolderName}/{image}")"
                         loading="lazy"
                         alt="@image"
                         width="300" height="300" />
                    <div class="overlay">
                        <span>View</span>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@if (lightboxImage != null)
{
    <div class="lightbox-backdrop" @onclick="CloseLightbox">
        <button class="lightbox-close" @onclick="CloseLightbox" @onclick:stopPropagation="true" aria-label="Close">&#x2715;</button>
        <img class="lightbox-img"
             src="@($"{baseUrl}images/{FolderName}/{lightboxImage}")"
             alt="@lightboxImage"
             @onclick:stopPropagation="true" />
    </div>
}

