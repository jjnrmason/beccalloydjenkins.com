@page "/image-gallery"
@inject NavigationManager NavigationManager

<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1.25rem;">
    @foreach (var folder in Folders)
    {
        <a href="@($"{baseUrl}folder/{folder.Name}")" class="gallery-card" style="display:block;text-decoration:none;">
            <div class="aspect-square-wrapper">
                <img src="@($"{baseUrl}images/{folder.Name}/{folder.Thumbnail}")"
                     loading="lazy"
                     alt="@folder.Description"
                     width="400" height="400" />
                <div class="overlay">
                    <span>@folder.Description</span>
                </div>
            </div>
            <div class="gallery-caption">@folder.Description</div>
        </a>
    }
</div>

@code {
    private string baseUrl = "/";

    protected override void OnInitialized()
    {
        baseUrl = NavigationManager.BaseUri;
    }

    private List<FolderModel> Folders = new List<FolderModel>
    {
        new FolderModel { Name = "383Canvas", Description = "383 Project", Thumbnail = "thumbnail.jpg" },
        new FolderModel { Name = "ChildrenBooks", Description = "Monty Moo Children's Book", Thumbnail = "thumbnail.JPG" },
        new FolderModel { Name = "CocaCola", Description = "Coca-Cola × World Cup", Thumbnail = "thumbnail.jpg" },
        new FolderModel { Name = "EmployabilityPortfolio", Description = "Employability Portfolio", Thumbnail = "thumbnail.png" },
        new FolderModel { Name = "FloralMural", Description = "Floral Mural", Thumbnail = "thumbnail.jpg" },
        new FolderModel { Name = "MenuDesign", Description = "1232 Menu Design", Thumbnail = "thumbnail.png" },
        new FolderModel { Name = "PigeonMag", Description = "Pigeon Magazine", Thumbnail = "thumbnail.jpg" },
        new FolderModel { Name = "Purify", Description = "Purify Website Design", Thumbnail = "thumbnail.png" },
        new FolderModel { Name = "REDCards", Description = "REDs Fortune Cards", Thumbnail = "thumbnail.JPG" },
        new FolderModel { Name = "SameDifference", Description = "Same Difference Festival", Thumbnail = "thumbnail.jpg" },
        new FolderModel { Name = "Stamps", Description = "King Charles Stamps", Thumbnail = "thumbnail.jpg" },
        new FolderModel { Name = "StarWarsMural", Description = "Star Wars Mural", Thumbnail = "thumbnail.jpg" },
        new FolderModel { Name = "Syrup", Description = "Syrup × Mental Health", Thumbnail = "thumbnail.jpg" },
