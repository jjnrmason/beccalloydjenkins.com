@page "/image-gallery"
@inject NavigationManager NavigationManager
@inject ImageService ImageService

@if (folders == null)
{
    <div style="display:flex;justify-content:center;padding:4rem;color:var(--color-text-muted);">Loading...</div>
}
else
{
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1.25rem;">
        @foreach (var folder in folders)
        {
            <a href="@($"{baseUrl}folder/{folder.Name}")" class="gallery-card" style="display:block;text-decoration:none;">
                <div class="aspect-square-wrapper">
                    <img src="@($"{baseUrl}images/{folder.Name}/{folder.Thumbnail}")"
                         loading="lazy"
                         alt="@folder.Title"
                         width="400" height="400" />
                    <div class="overlay">
                        <span>@folder.Title</span>
                    </div>
                </div>
                <div class="gallery-caption">@folder.Title</div>
            </a>
        }
    </div>
}

@code {
    private string baseUrl = "/";
    private List<FolderManifest>? folders;

    protected override void OnInitialized()
    {
        baseUrl = NavigationManager.BaseUri;
    }

    protected override async Task OnInitializedAsync()
    {
        folders = await ImageService.GetFoldersAsync();
    }
}
