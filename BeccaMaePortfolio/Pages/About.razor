@page "/about"
@inject NavigationManager NavigationManager

<PageTitle>About — Becca Lloyd-Jenkins</PageTitle>

<div class="page-content">
    <div style="max-width:900px;margin:0 auto;">

        <div style="display:flex;flex-direction:column;gap:2.5rem;">

            <!-- Top section: text + image -->
            <div style="display:grid;grid-template-columns:1fr;gap:2rem;align-items:start;" class="md:grid-cols-2-manual">
                <div>
                    <p style="font-size:0.8125rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:var(--color-accent);margin-bottom:0.75rem;">About me</p>
                    <h1 style="font-family:var(--font-heading);font-size:clamp(2rem,5vw,3.25rem);font-weight:400;line-height:1.15;margin-bottom:1.25rem;">
                        Hey there,<br/>I'm Becca
                    </h1>
                    <p style="color:var(--color-text-muted);margin-bottom:0.875rem;line-height:1.75;">
                        I'm a graphic designer, illustrator and digital marketer based in Shropshire who believes life's too short for boring designs.
                    </p>
                    <p style="color:var(--color-text-muted);margin-bottom:0.875rem;line-height:1.75;">
                        I love mixing creativity, colour, and a little bit of chaos into everything I do, and I'm always on the lookout for my next fun project!
                    </p>
                    <p style="color:var(--color-text-muted);margin-bottom:1.5rem;line-height:1.75;">
                        My mission is to create playful, compelling designs that spreads joy, sparks connection, and adds a little extra magic to everyday life… whether through vibrant illustrations, playful prints, or one-of-a-kind custom designs.
                    </p>

                    <div style="display:flex;flex-direction:column;gap:0.5rem;font-size:0.9375rem;">
                        <div style="display:flex;align-items:center;gap:0.5rem;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--color-accent);flex-shrink:0;">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                            </svg>
                            <a href="mailto:beccamaedesigns@outlook.com" style="color:var(--color-accent);">beccamaedesigns@outlook.com</a>
                        </div>
                        <div style="display:flex;align-items:center;gap:0.5rem;color:var(--color-text-muted);">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" style="color:var(--color-accent);flex-shrink:0;">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                            Shropshire, UK
                        </div>
                    </div>
                </div>

                <div style="display:flex;justify-content:center;">
                    <div style="position:relative;width:100%;max-width:380px;">
                        <img src="@($"{baseUrl}images/AboutMe.jpg")"
                             alt="Becca Lloyd-Jenkins"
                             style="width:100%;height:auto;border-radius:0.75rem;box-shadow:0 12px 40px rgba(0,0,0,0.12);transform:rotate(1deg);" />
                    </div>
                </div>
            </div>

            <!-- Life outside work -->
            <div style="background:var(--color-surface);border-radius:0.75rem;padding:1.75rem;border:1px solid var(--color-border);">
                <h2 style="font-family:var(--font-heading);font-size:1.5rem;font-weight:500;margin-bottom:1rem;">Outside the studio</h2>
                <p style="color:var(--color-text-muted);line-height:1.75;margin:0;">
                    In my spare time, you may find me having food with friends, making aesthetically pleasing latte art, cuddling with my miniature dachshund Peanut, or even baking up a sweet treat. However, I also love going to the gym, playing tennis and paddle boarding (even if i’m not that good at them!)                </p>
            </div>

        </div>
    </div>
</div>

<style>
    @@media (min-width: 768px) {
        .md\:grid-cols-2-manual {
            grid-template-columns: 1fr 1fr !important;
        }
    }
</style>

@code {
    private string baseUrl = "/";

    protected override void OnInitialized() {
        baseUrl = NavigationManager.BaseUri;
    }
}
